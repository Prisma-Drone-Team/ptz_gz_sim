<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="axis_camera">


    <xacro:property name="DEG_TO_RAD" value="0.017453293" />

    <link name="world">
    </link>

    <joint name="world_to_map" type="fixed">
        <parent link="world"/>
        <child link="map"/>
        <!-- <origin xyz="1.0 0.0 0.0" rpy="0.0 0.0 ${90*DEG_TO_RAD}"/> -->
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    </joint>

    <link name="map">
      <inertial>
        <origin xyz="0 0 0.5" rpy="0 0 0"/>
        <mass value="1"/>
        <inertia ixx="100"  ixy="0"  ixz="0" iyy="100" iyz="0" izz="100" />
      </inertial>
    </link>

    <joint name="map_to_footprint" type="fixed">
        <parent link="map"/>
        <child link="axis_footprint"/>
        <!-- <origin xyz="1.0 0.0 0.0" rpy="0.0 0.0 ${90*DEG_TO_RAD}"/> -->
        <origin xyz="7.0 -1.0 0.0" rpy="0.0 0.0 0.0"/>
    </joint>
    
    <link name="axis_footprint">
        <inertial>
          <origin xyz="0 0 0.5" rpy="0 0 0"/>
          <mass value="1"/>
          <inertia ixx="100"  ixy="0"  ixz="0" iyy="100" iyz="0" izz="100" />
        </inertial>
    </link>

    <joint name="footprint_to_camera" type="fixed">
        <parent link="axis_footprint"/>
        <child link="axis_camera_frame"/>
        <origin xyz="0.0 0.0 1.8" rpy="${180*DEG_TO_RAD} 0.0 ${90*DEG_TO_RAD}"/>
    </joint>

    <link name="axis_camera_frame">
        <inertial>
          <origin xyz="0 0 0.05" rpy="0 0 0"/>
          <mass value="1"/>
          <inertia ixx="100"  ixy="0"  ixz="0" iyy="100" iyz="0" izz="100" />
        </inertial>
    
        <visual>
          <origin xyz="0 0 0.045" rpy="0 0 0" />
          <geometry>
            <cylinder radius="0.165" length="0.09"/>
          </geometry>
          <material name="Blue">
            <color rgba="0 0.0 1.0 1.0"/>
          </material>
        </visual>
        <visual>
          <origin xyz="0 0 ${0.09 + 0.01}" rpy="0 0 0" />
          <geometry>
            <cylinder radius="0.116" length="0.02"/>
          </geometry>
          <material name="Cyan">
            <color rgba="0 1.0 1.0 0.4"/>
          </material>
        </visual>
        <visual>
          <origin xyz="0 0 ${0.09 + 0.02}" rpy="0 0 0" />
          <geometry>
            <sphere radius="0.116"/>
          </geometry>
          <material name="Cyan">
            <color rgba="0 1.0 1.0 0.4"/>
          </material>
        </visual>
    </link>

    <joint name="pan_joint" type="revolute">
        <parent link="axis_camera_frame"/>
        <child link="pan_link"/>
        <origin xyz="0.0 0.0 ${0.09 + 0.05}" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 0.0 1.0"/>
        <limit lower="-1000.0" upper="1000.0" effort="1000.0" velocity="1000.0"/>
    </joint>

    <link name="pan_link">
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="1.0"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
    </link>

    <joint name="tilt_joint" type="revolute">
        <parent link="pan_link"/>
        <child link="tilt_link"/>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 1.0 0.0"/>
        <limit lower="-1000.0" upper="1000.0" effort="1000.0" velocity="1000.0"/>
    </joint>

    <link name="tilt_link">
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="1.0"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
    </link>

    <gazebo reference="pan_joint">
        <provideFeedback>true</provideFeedback>
        <damping>0.1</damping>
        <friction>0.01</friction>
    </gazebo>

    <gazebo reference="tilt_joint">
        <provideFeedback>true</provideFeedback>
        <damping>0.1</damping>
        <friction>0.01</friction>
    </gazebo>

    <link name="axis_camera_optical">
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="1.0"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
    </link>

    <joint name="axis_camera_optical_joint" type="fixed">
        <parent link="tilt_link"/>
        <child link="axis_camera_optical"/>
        <origin xyz="0.0 0.0 0.0" rpy="3.1415 0.0 0.0"/>
    </joint>

    <!-- Import ros2_control configuration -->
    <xacro:include filename="ptz.ros2_control.xacro" />
    <xacro:ptz_ros2_control name="MockSystem" />

    <gazebo reference="axis_camera_optical">
    <sensor name="ptz_camera" type="camera">
      <pose>0 0 0 0 0 0</pose>
      <topic>/image_raw</topic>
      <camera>
        <horizontal_fov>1.0786</horizontal_fov>
        <camera_info_topic>/image_raw/camera_info</camera_info_topic>
        <optical_frame_id>axis_camera_optical</optical_frame_id>
        <image>
          <width>1920</width>
          <height>1080</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>

      </camera>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      
      <!-- CameraZoomPlugin Configuration - COMMENTED OUT FOR NOW -->
      <!-- 
      <plugin name="CameraZoomPlugin" filename="CameraZoomPlugin">
        <max_zoom>125.0</max_zoom>
        <slew_rate>0.425</slew_rate>
        <topic>ptz_zoom_cmd</topic>
        <fb_topic>ptz_zoom_fb</fb_topic>
      </plugin>
      -->
      
    </sensor>
  </gazebo>

</robot>